<mvc:View
  controllerName="csv.crud.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form"
  displayBlock="true">

  <App>
    <Page title="CSV Items (Local CSV CRUD)">
      <content>
        <VBox class="sapUiSmallMargin">
          <Toolbar>
            <Title text="Items"/>
            <ToolbarSpacer/>
            <SearchField width="20rem" liveChange=".onSearch" placeholder="Search by ID or Name"/>
            <ToolbarSpacer/>
            <Button text="Add" type="Emphasized" press=".onAdd"/>
            <Button text="Edit" press=".onEdit" enabled="{= ${itemsModel>/selectedId} ? true : false }"/>
            <Button text="Delete" type="Negative" press=".onDelete" enabled="{= ${itemsModel>/selectedId} ? true : false }"/>
            <Button text="Refresh" press=".onRefresh"/>
          </Toolbar>
          <Table id="table"
                mode="SingleSelectLeft"
                items="{itemsModel>/items}"
                growing="true"
                selectionChange=".onSelect">
            <columns>
              <Column width="8rem"><Text text="ID"/></Column>
              <Column><Text text="Name"/></Column>
              <Column width="10rem" hAlign="End"><Text text="Price"/></Column>
              <Column width="10rem" hAlign="End"><Text text="Quantity"/></Column>
            </columns>
            <items>
              <ColumnListItem type="Active" press=".onEdit">
                <cells>
                  <ObjectIdentifier title="{itemsModel>id}"/>
                  <Text text="{itemsModel>name}"/>
                  <ObjectNumber number="{itemsModel>price}" unit="₹"/>
                  <Text text="{itemsModel>quantity}"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </VBox>
      </content>
    </Page>
  </App>
</mvc:View>
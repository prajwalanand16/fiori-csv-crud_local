<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:form="sap.ui.layout.form">
  <Dialog id="editDialog" title="{= ${editModel>/id} ? 'Edit Item' : 'Add Item' }">
    <content>
      <form:SimpleForm editable="true" layout="ResponsiveGridLayout">
        <Label text="ID"/>
        <Input value="{editModel>/id}" editable="false" placeholder="Will be auto-generated for new item"/>
        <Label text="Name"/>
        <Input value="{editModel>/name}" required="true" placeholder="Item name"/>
        <Label text="Price"/>
        <Input value="{editModel>/price}" type="Number" placeholder="e.g., 99"/>
        <Label text="Quantity"/>
        <Input value="{editModel>/quantity}" type="Number" placeholder="e.g., 10"/>
      </form:SimpleForm>
    </content>
    <beginButton>
      <Button text="Save" type="Emphasized" press=".onDialogSave"/>
    </beginButton>
    <endButton>
      <Button text="Cancel" press=".onDialogCancel"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>
